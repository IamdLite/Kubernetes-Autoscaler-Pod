{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "HPA scaling, pod resource usage, and request rate for the hpa-demo-app deployment.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisLabel": "replicas", "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "kube_horizontalpodautoscaler_status_current_replicas{namespace=\"hpa-demo\",horizontalpodautoscaler=\"hpa-demo-app\"}",
          "legendFormat": "current",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "kube_horizontalpodautoscaler_status_desired_replicas{namespace=\"hpa-demo\",horizontalpodautoscaler=\"hpa-demo-app\"}",
          "legendFormat": "desired",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "kube_horizontalpodautoscaler_spec_min_replicas{namespace=\"hpa-demo\",horizontalpodautoscaler=\"hpa-demo-app\"}",
          "legendFormat": "min",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "kube_horizontalpodautoscaler_spec_max_replicas{namespace=\"hpa-demo\",horizontalpodautoscaler=\"hpa-demo-app\"}",
          "legendFormat": "max",
          "refId": "D"
        }
      ],
      "title": "HPA Replicas (current / desired / min / max)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 50 },
            { "color": "red", "value": 80 }
          ]},
          "unit": "percent"
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "avg(rate(container_cpu_usage_seconds_total{namespace=\"hpa-demo\",pod=~\"hpa-demo-app-.*\",container=\"app\"}[1m])) / avg(kube_pod_container_resource_requests{namespace=\"hpa-demo\",pod=~\"hpa-demo-app-.*\",resource=\"cpu\"}) * 100",
          "legendFormat": "avg CPU %",
          "refId": "A"
        }
      ],
      "title": "Avg CPU Utilization vs Request (target: 50%)",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 9 },
      "id": 3,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{namespace=\"hpa-demo\",pod=~\"hpa-demo-app-.*\",container=\"app\"}[1m]) / on(pod) group_left() kube_pod_container_resource_requests{namespace=\"hpa-demo\",resource=\"cpu\"} * 100",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "title": "Per-Pod CPU Utilization (% of request)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 9 },
      "id": 4,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "container_memory_working_set_bytes{namespace=\"hpa-demo\",pod=~\"hpa-demo-app-.*\",container=\"app\"} / on(pod) group_left() kube_pod_container_resource_requests{namespace=\"hpa-demo\",resource=\"memory\"} * 100",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "title": "Per-Pod Memory Utilization (% of request)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "fillOpacity": 50, "lineWidth": 1 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
      "id": 5,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "count(kube_pod_status_phase{namespace=\"hpa-demo\",pod=~\"hpa-demo-app-.*\",phase=\"Running\"})",
          "legendFormat": "running pods",
          "refId": "A"
        }
      ],
      "title": "Running Pods Over Time",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["hpa", "autoscaling", "demo"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "HPA Demo — Pod Autoscaler Dashboard",
  "uid": "hpa-demo-board",
  "version": 1,
  "weekStart": ""
}
